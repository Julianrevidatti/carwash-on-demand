<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/search_bar_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Agregar Vehículo"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etBrand"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Marca (Ej: Volkswagen)"
        android:background="@drawable/edit_text_background"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:inputType="textCapWords"/>

    <EditText
        android:id="@+id/etModel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Modelo (Ej: Gol Power)"
        android:background="@drawable/edit_text_background"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:inputType="textCapWords"/>

    <EditText
        android:id="@+id/etPlate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Patente (Ej: ABC123)"
        android:background="@drawable/edit_text_background"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:inputType="textCapCharacters"/>

    <EditText
        android:id="@+id/etType"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Tipo (Ej: Sedan, SUV)"
        android:background="@drawable/edit_text_background"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:inputType="textCapWords"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Eliminar"
            android:textAllCaps="false"
            android:textColor="@color/red"
            app:cornerRadius="24dp"
            app:strokeColor="@color/red" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Confirmar"
            android:textAllCaps="false"
            android:backgroundTint="@color/azulcarwash"
            app:cornerRadius="24dp" />

    </LinearLayout>

</LinearLayout>
